# Paths
WORKSPACE=/home/youruser/projects/my-workspace
CLAUDE_CONFIG=/home/youruser/.claude-agent
CODEX_CONFIG=/home/youruser/.codex-agent
QWEN_CONFIG=/home/youruser/.qwen-agent

# API keys
MIND_API_KEY=YOUR_MIND_API_KEY
ASR_TOKEN=YOUR_ASR_TOKEN

# ASR settings
ASR_NORMALIZE=false

# TTS voice (kseniya, aidar, xenia, eugene, baya, random)
TTS_VOICE=aidar

# Auth
AUTH_LOGIN=admin
AUTH_PASSWORD=YOUR_PASSWORD
SECRET_KEY=YOUR_SECRET_KEY
